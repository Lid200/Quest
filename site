// ===== VIEWS =====
function showView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + name).classList.add('active');
  const tabs = { map: 0, character: 1 };
  if (tabs[name] !== undefined) {
    document.querySelectorAll('.tab-btn')[tabs[name]].classList.add('active');
  }
}

// ===== RENDER WORLDS =====
function renderWorlds() {
  const grid = document.getElementById('worldsGrid');
  grid.innerHTML = '';
  state.worlds.forEach(world => {
    const doneCount = world.branches.filter(b => b.done).length;
    const totalUnlocked = world.branches.filter(b => b.unlocked).length;
    const pct = totalUnlocked > 0 ? Math.round((doneCount / world.branches.length) * 100) : 0;

    const card = document.createElement('div');
    card.className = 'world-card' + (world.unlocked ? '' : ' locked');
    card.style.cssText = `--world-color: ${world.color}; --world-gradient: ${world.gradient}; --world-glow: ${world.glow};`;
    card.innerHTML = `
      <div class="world-banner" style="background: ${world.gradient}">
        <div class="world-sparkles"></div>
        <div class="world-emoji">${world.emoji}</div>
        ${!world.unlocked ? '<div class="lock-overlay">🔒</div>' : ''}
      </div>
      <div class="world-info">
        <div class="world-name">${world.name}</div>
        <div class="world-desc">${world.desc}</div>
        <div class="world-progress">
          <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
          <div class="progress-text">${doneCount}/${world.branches.length} branches</div>
        </div>
        <div class="world-badges">
          ${world.branches.slice(0,3).map(b => `<div class="badge ${b.done ? 'unlocked' : ''}">${b.icon} ${b.name}</div>`).join('')}
          ${world.branches.length > 3 ? `<div class="badge">+${world.branches.length-3}</div>` : ''}
        </div>
      </div>`;
    if (world.unlocked) {
      card.onclick = () => showWorldDetail(world.id);
    } else {
      card.title = 'Passez des entretiens pour débloquer cet univers !';
    }
    grid.appendChild(card);
  });
}

// ===== WORLD DETAIL =====
function showWorldDetail(worldId) {
  const world = state.worlds.find(w => w.id === worldId);
  const container = document.getElementById('worldDetailContent');
  container.style.cssText = `--world-color: ${world.color}; --world-gradient: ${world.gradient};`;
  container.innerHTML = `
    <div class="world-detail-header" style="--world-gradient: ${world.gradient}">
      <button class="back-btn" onclick="showView('map')">← Retour</button>
      <div class="detail-emoji">${world.emoji}</div>
      <div class="detail-title">
        <h2>${world.name}</h2>
        <p>${world.desc}</p>
      </div>
    </div>
    <div class="branches-grid" id="branchesGrid"></div>`;

  const grid = document.getElementById('branchesGrid');
  world.branches.forEach(branch => {
    const card = document.createElement('div');
    let statusClass = branch.unlocked ? (branch.done ? 'completed-branch' : '') : 'locked-branch';
    let statusHtml = branch.done
      ? `<div class="branch-status status-done"><div class="status-dot"></div>Complété ✓</div>`
      : branch.unlocked
        ? `<div class="branch-status status-available"><div class="status-dot"></div>Disponible</div>`
        : `<div class="branch-status status-locked"><div class="status-dot"></div>Verrouillé 🔒</div>`;

    card.className = `branch-card ${statusClass}`;
    card.style.cssText = `--world-color: ${world.color};`;
    card.innerHTML = `
      <div class="branch-xp">+${branch.xp} XP</div>
      <div class="branch-icon">${branch.icon}</div>
      <div class="branch-name">${branch.name}</div>
      <div class="branch-desc">${branch.desc}</div>
      ${statusHtml}`;

    if (branch.unlocked && !branch.done) {
      card.onclick = () => openInterview(worldId, branch.id);
    } else if (!branch.unlocked) {
      card.title = 'Passez d\'autres entretiens pour débloquer cette branche !';
    }
    grid.appendChild(card);
  });

  showView('world');
}

// ===== INTERVIEW MODAL =====
function openInterview(worldId, branchId) {
  const world = state.worlds.find(w => w.id === worldId);
  const branch = world.branches.find(b => b.id === branchId);
  if (!branch || !branch.unlocked || branch.done) return;

  currentInterviewTarget = { worldId, branchId };
  const student = STUDENT_PROFILES[branchId] || { name: 'Étudiant·e', avatar: '🎓', detail: 'Étudiant·e passionné·e', quote: 'Posez-moi toutes vos questions !' };

  document.getElementById('interviewModalContent').innerHTML = `
    <span class="modal-emoji">${branch.icon}</span>
    <div class="modal-title">Entretien — ${branch.name}</div>
    <div class="modal-subtitle">${world.name}</div>
    <div class="student-card">
      <div class="student-avatar">${student.avatar}</div>
      <div class="student-info">
        <div class="student-name">${student.name}</div>
        <div class="student-detail">${student.detail}<br><em style="color:#8888aa; margin-top:4px; display:block">"${student.quote}"</em></div>
      </div>
    </div>
    <div class="modal-rewards">
      <div class="modal-rewards-title">🎁 RÉCOMPENSES</div>
      <div class="reward-list">
        <div class="reward-pill">+${branch.xp} XP</div>
        <div class="reward-pill">+10 Maturité</div>
        <div class="reward-pill">+8 Connaissance de soi</div>
        ${branch.id === branchId ? '<div class="reward-pill">🔓 Nouvelle branche</div>' : ''}
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-primary" onclick="completeInterview()">✅ Marquer comme réalisé</button>
      <button class="btn-secondary" onclick="closeModal('interviewModal')">Plus tard</button>
    </div>`;

  document.getElementById('interviewModal').classList.add('open');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

// ===== COMPLETE INTERVIEW =====
function completeInterview() {
  if (!currentInterviewTarget) return;
  const { worldId, branchId } = currentInterviewTarget;
  const world = state.worlds.find(w => w.id === worldId);
  const branch = world.branches.find(b => b.id === branchId);

  branch.done = true;
  const xpGained = branch.xp;
  state.xp += xpGained;
  state.stats.maturite = Math.min(100, state.stats.maturite + 10);
  state.stats.connaissance = Math.min(100, state.stats.connaissance + 8);
  state.stats.exploration = Math.min(100, state.stats.exploration + 5);
  state.stats.reseau = Math.min(100, state.stats.reseau + 7);

  // Unlock next branch
  const branchIdx = world.branches.findIndex(b => b.id === branchId);
  const nextBranch = world.branches[branchIdx + 1];
  let unlockedName = null;
  if (nextBranch && !nextBranch.unlocked) {
    nextBranch.unlocked = true;
    unlockedName = nextBranch.name;
  }

  // Unlock a new world if enough interviews
  const totalDone = state.worlds.flatMap(w => w.branches).filter(b => b.done).length;
  let unlockedWorld = null;
  if (totalDone >= 2) {
    const locked = state.worlds.find(w => !w.unlocked);
    if (locked) { locked.unlocked = true; unlockedWorld = locked.name; }
  }

  // Level up
  const oldLevel = state.level;
  if (state.xp >= 500) state.level = 3;
  else if (state.xp >= 250) state.level = 2;
  const leveled = state.level > oldLevel;

  // Add interview to log
  const student = STUDENT_PROFILES[branchId] || { name: 'Étudiant·e', avatar: '🎓' };
  state.interviews.unshift({ branch, world, student, xp: xpGained, date: 'Aujourd\'hui' });

  closeModal('interviewModal');

  // Show success modal
  setTimeout(() => {
    document.getElementById('successModalContent').innerHTML = `
      <div class="confetti-line">🎉🌟✨🎊💫</div>
      <div class="modal-title">Entretien terminé !</div>
      <div class="modal-subtitle">${student.name} • ${branch.name}</div>
      <div class="xp-gained">+${xpGained} XP</div>
      ${unlockedName ? `<div class="unlocked-stuff"><div class="unlocked-title">🔓 DÉBLOQUÉ</div><div class="unlocked-item">Nouvelle branche : ${unlockedName}</div></div>` : ''}
      ${unlockedWorld ? `<div class="unlocked-stuff" style="border-color:rgba(247,201,72,0.3); background:rgba(247,201,72,0.08)"><div class="unlocked-title" style="color:var(--accent)">🌍 NOUVEL UNIVERS DÉBLOQUÉ !</div><div class="unlocked-item">${unlockedWorld}</div></div>` : ''}
      ${leveled ? `<div class="unlocked-stuff" style="border-color:rgba(255,107,157,0.4); background:rgba(255,107,157,0.1)"><div class="unlocked-title" style="color:#ff6b9d">⬆️ NIVEAU SUPÉRIEUR !</div><div class="unlocked-item">Tu es maintenant niveau ${state.level} !</div></div>` : ''}
      <div class="modal-actions" style="margin-top:20px">
        <button class="btn-primary" onclick="closeModal('successModal'); updateAll()">Super ! Continuer 🚀</button>
      </div>`;
    document.getElementById('successModal').classList.add('open');
    spawnParticles();
    if (leveled) setTimeout(() => showLevelUpToast(), 600);
  }, 300);
}

function updateAll() {
  renderWorlds();
  updateCharacter();
  if (document.getElementById('view-world').classList.contains('active') && currentInterviewTarget) {
    showWorldDetail(currentInterviewTarget.worldId);
  }
}

// ===== CHARACTER UPDATE =====
function updateCharacter() {
  const { stats, xp, level, interviews } = state;

  // Stats bars
  ['maturite','connaissance','exploration','reseau'].forEach(s => {
    const key = s === 'connaissance' ? 'connaissance' : s;
    const val = stats[key] || stats[s] || 0;
    const bar = document.getElementById('stat-' + s);
    const valEl = document.getElementById('val-' + s);
    if (bar) bar.style.width = val + '%';
    if (valEl) valEl.textContent = val;
  });

  // Level & XP
  document.getElementById('levelBadge').textContent = level;
  document.getElementById('playerXpHeader').textContent = xp + ' XP';
  const xpPct = ((xp % 250) / 250) * 100;
  document.getElementById('headerXpBar').style.width = xpPct + '%';

  // Avatar evolution
  const avatar = document.getElementById('bigAvatar');
  const emoji = document.getElementById('bigAvatarEmoji');
  const headerEmoji = document.getElementById('headerEmoji');
  avatar.className = 'big-avatar' + (level >= 3 ? ' level3' : level >= 2 ? ' level2' : '');
  const emojiMap = { 1: '🧑‍🎓', 2: '🧑‍💼', 3: '🧑‍🏫' };
  emoji.textContent = emojiMap[level] || '🧑‍🎓';
  headerEmoji.textContent = emojiMap[level] || '🧑‍🎓';

  const levelNames = { 1: 'Lycéen Explorateur', 2: 'Aventurier Curieux', 3: 'Maître Orienté' };
  document.getElementById('charLevel').textContent = `${levelNames[level]} • Niveau ${level}`;

  // Achievements
  const totalDone = state.interviews.length;
  if (totalDone >= 3) document.getElementById('ach-3int').classList.add('earned');
  if (totalDone >= 5) document.getElementById('ach-5int').classList.add('earned');
  const worldsExplored = state.worlds.filter(w => w.branches.some(b => b.done)).length;
  if (worldsExplored >= 2) document.getElementById('ach-2worlds').classList.add('earned');
  if (stats.reseau >= 50) document.getElementById('ach-social').classList.add('earned');

  // Interview log
  const log = document.getElementById('interviewLog');
  if (state.interviews.length === 0) {
    log.innerHTML = `<div style="text-align:center; color: var(--muted); padding: 20px; font-size:0.9rem;">Aucun entretien pour l'instant.<br>Explore les univers pour commencer ! 🚀</div>`;
  } else {
    log.innerHTML = state.interviews.map(i => `
      <div class="interview-item">
        <div class="interview-icon">${i.branch.icon}</div>
        <div class="interview-info">
          <div class="interview-title">${i.student.name} — ${i.branch.name}</div>
          <div class="interview-meta">${i.world.name} • ${i.date}</div>
        </div>
        <div class="interview-xp">+${i.xp} XP</div>
      </div>`).join('');
  }
}

// ===== PARTICLES =====
function spawnParticles() {
  const emojis = ['⭐','✨','🎉','🌟','💫','🎊','🎯','🚀'];
  for (let i = 0; i < 12; i++) {
    setTimeout(() => {
      const p = document.createElement('div');
      p.className = 'particle';
      p.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      p.style.left = (20 + Math.random() * 60) + 'vw';
      p.style.top = (20 + Math.random() * 60) + 'vh';
      document.body.appendChild(p);
      setTimeout(() => p.remove(), 2000);
    }, i * 80);
  }
}

function showLevelUpToast() {
  const toast = document.createElement('div');
  toast.className = 'levelup-toast';
  toast.textContent = `⬆️ NIVEAU ${state.level} ! Tu évolues !`;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 3000);
}

// ===== CLOSE ON OVERLAY CLICK =====
document.getElementById('interviewModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal('interviewModal');
});
document.getElementById('successModal').addEventListener('click', function(e) {
  if (e.target === this) { closeModal('successModal'); updateAll(); }
});

// ===== START =====
init();
</script>
</body>
</html>
