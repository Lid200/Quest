<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OrientQuest — Explore ton futur</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d1a;
    --card: #16162a;
    --accent: #f7c948;
    --accent2: #ff6b9d;
    --accent3: #4ecdc4;
    --text: #f0eeff;
    --muted: #8888aa;
    --xp-bar: #2a2a44;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Nunito', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* STARS BACKGROUND */
  .stars {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background: radial-gradient(ellipse at 20% 50%, rgba(78,205,196,0.07) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(247,201,72,0.07) 0%, transparent 60%);
  }
  .stars::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.8) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.15;
    animation: twinkle 4s infinite alternate;
  }
  @keyframes twinkle { from { opacity: 0.1; } to { opacity: 0.25; } }

  /* LAYOUT */
  .app { position: relative; z-index: 1; display: flex; flex-direction: column; min-height: 100vh; }

  /* HEADER */
  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 32px;
    background: rgba(22,22,42,0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(247,201,72,0.2);
    position: sticky; top: 0; z-index: 100;
  }
  .logo {
    font-family: 'Fredoka One', cursive;
    font-size: 1.8rem;
    color: var(--accent);
    text-shadow: 0 0 20px rgba(247,201,72,0.5);
    letter-spacing: 1px;
  }
  .logo span { color: var(--accent2); }

  .header-right { display: flex; align-items: center; gap: 20px; }

  /* PLAYER MINI */
  .player-mini {
    display: flex; align-items: center; gap: 12px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 8px 16px;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s;
  }
  .player-mini:hover { border-color: var(--accent); background: rgba(247,201,72,0.1); }
  .avatar-mini {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    border: 2px solid var(--accent);
    position: relative;
    overflow: hidden;
  }
  .level-badge {
    position: absolute; bottom: -2px; right: -2px;
    background: var(--accent); color: #000;
    width: 16px; height: 16px; border-radius: 50%;
    font-size: 0.6rem; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
  }
  .player-name { font-weight: 800; font-size: 0.9rem; }
  .player-xp { font-size: 0.75rem; color: var(--accent); }

  /* XP BAR */
  .xp-global {
    height: 4px; width: 100px;
    background: var(--xp-bar);
    border-radius: 2px; overflow: hidden;
  }
  .xp-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 2px;
    transition: width 1s ease;
  }

  /* NAV TABS */
  .nav-tabs {
    display: flex; gap: 4px;
    background: rgba(255,255,255,0.04);
    padding: 4px;
    border-radius: 12px;
  }
  .tab-btn {
    padding: 8px 18px;
    border: none; background: transparent;
    color: var(--muted); font-family: 'Nunito', sans-serif;
    font-weight: 700; font-size: 0.85rem;
    border-radius: 8px; cursor: pointer;
    transition: all 0.2s;
  }
  .tab-btn.active, .tab-btn:hover {
    background: rgba(247,201,72,0.15);
    color: var(--accent);
  }
  .tab-btn.active { background: rgba(247,201,72,0.2); }

  /* MAIN CONTENT */
  main { flex: 1; padding: 32px; max-width: 1400px; margin: 0 auto; width: 100%; }

  /* VIEWS */
  .view { display: none; }
  .view.active { display: block; }

  /* ===== MAP VIEW ===== */
  .map-header {
    text-align: center; margin-bottom: 40px;
  }
  .map-header h1 {
    font-family: 'Fredoka One', cursive;
    font-size: 2.5rem; color: var(--accent);
    text-shadow: 0 0 30px rgba(247,201,72,0.4);
    margin-bottom: 8px;
  }
  .map-header p { color: var(--muted); font-size: 1.05rem; }

  .worlds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .world-card {
    background: var(--card);
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
  }
  .world-card:hover {
    transform: translateY(-8px) scale(1.02);
    border-color: var(--world-color);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px var(--world-glow);
  }
  .world-card.locked { opacity: 0.5; cursor: not-allowed; }
  .world-card.locked:hover { transform: none; box-shadow: none; }

  .world-banner {
    height: 140px;
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem;
    position: relative;
    overflow: hidden;
  }
  .world-banner::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--world-gradient);
    opacity: 0.85;
  }
  .world-emoji { position: relative; z-index: 1; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4)); }
  .world-sparkles {
    position: absolute; inset: 0; z-index: 1;
    background-image: radial-gradient(circle, rgba(255,255,255,0.6) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.2;
  }

  .lock-overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.6);
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem; z-index: 2;
  }

  .world-info { padding: 20px; }
  .world-name {
    font-family: 'Fredoka One', cursive;
    font-size: 1.4rem; margin-bottom: 4px;
    color: var(--world-color);
  }
  .world-desc { font-size: 0.85rem; color: var(--muted); margin-bottom: 16px; line-height: 1.5; }

  .world-progress {
    display: flex; align-items: center; gap: 10px;
  }
  .progress-bar {
    flex: 1; height: 8px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px; overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--world-gradient);
    border-radius: 4px;
    transition: width 1.5s ease;
  }
  .progress-text { font-size: 0.75rem; font-weight: 700; color: var(--world-color); white-space: nowrap; }

  .world-badges {
    display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px;
  }
  .badge {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 3px 10px; border-radius: 20px;
    font-size: 0.7rem; font-weight: 700; color: var(--muted);
  }
  .badge.unlocked {
    background: rgba(78,205,196,0.15);
    border-color: var(--accent3);
    color: var(--accent3);
  }

  /* ===== WORLD DETAIL VIEW ===== */
  .world-detail-header {
    display: flex; align-items: center; gap: 20px;
    margin-bottom: 32px; padding: 28px;
    border-radius: 20px; position: relative; overflow: hidden;
  }
  .world-detail-header::before {
    content: ''; position: absolute; inset: 0;
    background: var(--world-gradient); opacity: 0.2;
  }
  .back-btn {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--text); padding: 10px 20px;
    border-radius: 50px; cursor: pointer;
    font-family: 'Nunito', sans-serif;
    font-weight: 700; font-size: 0.9rem;
    transition: all 0.2s;
  }
  .back-btn:hover { background: rgba(255,255,255,0.15); }

  .detail-emoji { font-size: 3rem; position: relative; z-index: 1; }
  .detail-title {
    position: relative; z-index: 1;
  }
  .detail-title h2 {
    font-family: 'Fredoka One', cursive; font-size: 2rem;
    color: var(--world-color);
  }
  .detail-title p { color: var(--muted); margin-top: 4px; }

  .branches-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }

  .branch-card {
    background: var(--card);
    border: 2px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 20px;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .branch-card:hover:not(.locked-branch) {
    border-color: var(--world-color);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }
  .branch-card.locked-branch { opacity: 0.45; cursor: not-allowed; }
  .branch-card.completed-branch { border-color: rgba(78,205,196,0.5); }

  .branch-icon { font-size: 2rem; margin-bottom: 12px; }
  .branch-name { font-weight: 800; font-size: 1rem; margin-bottom: 6px; }
  .branch-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.4; margin-bottom: 12px; }

  .branch-status {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.75rem; font-weight: 700;
  }
  .status-dot {
    width: 8px; height: 8px; border-radius: 50%;
  }
  .status-available .status-dot { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
  .status-locked .status-dot { background: var(--muted); }
  .status-done .status-dot { background: var(--accent3); box-shadow: 0 0 6px var(--accent3); }

  .branch-xp {
    position: absolute; top: 12px; right: 12px;
    background: rgba(247,201,72,0.15);
    border: 1px solid rgba(247,201,72,0.3);
    color: var(--accent); font-size: 0.7rem; font-weight: 800;
    padding: 3px 8px; border-radius: 20px;
  }

  /* ===== CHARACTER VIEW ===== */
  .char-layout {
    display: grid; grid-template-columns: 340px 1fr; gap: 32px;
  }

  .char-card {
    background: var(--card);
    border-radius: 24px; padding: 32px;
    border: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }

  .big-avatar {
    width: 120px; height: 120px; border-radius: 50%;
    margin: 0 auto 16px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    border: 4px solid var(--accent);
    box-shadow: 0 0 40px rgba(247,201,72,0.3);
    position: relative;
    transition: all 0.5s;
  }
  .big-avatar.level2 { background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); border-color: var(--accent2); }
  .big-avatar.level3 { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border-color: var(--accent3); }

  .char-name {
    font-family: 'Fredoka One', cursive; font-size: 1.5rem;
    color: var(--accent); margin-bottom: 4px;
  }
  .char-level { color: var(--muted); font-size: 0.9rem; margin-bottom: 24px; }

  .stat-row {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 14px;
  }
  .stat-label { font-size: 0.8rem; font-weight: 700; width: 110px; text-align: left; color: var(--muted); }
  .stat-bar { flex: 1; height: 10px; background: rgba(255,255,255,0.08); border-radius: 5px; overflow: hidden; }
  .stat-fill {
    height: 100%; border-radius: 5px;
    transition: width 1.5s ease;
  }
  .stat-val { font-size: 0.8rem; font-weight: 800; width: 36px; text-align: right; }

  .achievements {
    margin-top: 24px; display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;
  }
  .achievement {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px; padding: 8px 12px;
    text-align: center; font-size: 0.75rem;
    transition: all 0.3s;
  }
  .achievement.earned {
    background: rgba(247,201,72,0.1);
    border-color: rgba(247,201,72,0.4);
    color: var(--accent);
  }
  .achievement-icon { font-size: 1.2rem; display: block; margin-bottom: 2px; }

  /* RIGHT SIDE */
  .char-right { display: flex; flex-direction: column; gap: 20px; }

  .interview-log {
    background: var(--card);
    border-radius: 20px; padding: 24px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .section-title {
    font-family: 'Fredoka One', cursive; font-size: 1.3rem;
    color: var(--accent); margin-bottom: 16px;
    display: flex; align-items: center; gap: 8px;
  }

  .interview-item {
    display: flex; align-items: center; gap: 16px;
    padding: 14px; border-radius: 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 10px;
    transition: all 0.3s;
  }
  .interview-item:hover { background: rgba(255,255,255,0.06); }
  .interview-icon { font-size: 1.5rem; }
  .interview-info { flex: 1; }
  .interview-title { font-weight: 800; font-size: 0.9rem; }
  .interview-meta { font-size: 0.75rem; color: var(--muted); margin-top: 2px; }
  .interview-xp {
    background: rgba(78,205,196,0.15);
    color: var(--accent3);
    font-size: 0.75rem; font-weight: 800;
    padding: 4px 10px; border-radius: 20px;
    border: 1px solid rgba(78,205,196,0.3);
  }

  .next-interviews {
    background: var(--card);
    border-radius: 20px; padding: 24px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .upcoming-card {
    display: flex; align-items: center; gap: 16px;
    padding: 16px; border-radius: 14px;
    background: linear-gradient(135deg, rgba(247,201,72,0.08), rgba(255,107,157,0.08));
    border: 1px solid rgba(247,201,72,0.2);
    margin-bottom: 12px; cursor: pointer;
    transition: all 0.3s;
  }
  .upcoming-card:hover { transform: translateX(4px); border-color: var(--accent); }
  .upcoming-emoji { font-size: 2rem; }
  .upcoming-info { flex: 1; }
  .upcoming-name { font-weight: 800; }
  .upcoming-detail { font-size: 0.8rem; color: var(--muted); margin-top: 2px; }
  .upcoming-btn {
    background: var(--accent); color: #000;
    font-family: 'Nunito', sans-serif; font-weight: 800;
    font-size: 0.8rem; padding: 8px 16px;
    border-radius: 50px; border: none; cursor: pointer;
    transition: all 0.2s;
  }
  .upcoming-btn:hover { transform: scale(1.05); box-shadow: 0 4px 15px rgba(247,201,72,0.4); }

  /* ===== INTERVIEW MODAL ===== */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.8);
    z-index: 1000; display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.3s;
    backdrop-filter: blur(6px);
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal {
    background: var(--card);
    border-radius: 24px; padding: 40px;
    max-width: 540px; width: 90%;
    border: 1px solid rgba(255,255,255,0.12);
    transform: scale(0.9) translateY(20px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
  }
  .modal-overlay.open .modal { transform: scale(1) translateY(0); }

  .modal-emoji { font-size: 4rem; text-align: center; display: block; margin-bottom: 16px; }
  .modal-title {
    font-family: 'Fredoka One', cursive; font-size: 1.8rem;
    text-align: center; color: var(--accent); margin-bottom: 8px;
  }
  .modal-subtitle { text-align: center; color: var(--muted); margin-bottom: 28px; font-size: 0.95rem; }

  .student-card {
    display: flex; gap: 16px; align-items: center;
    background: rgba(255,255,255,0.05); border-radius: 14px; padding: 16px;
    margin-bottom: 24px;
  }
  .student-avatar { font-size: 2.5rem; }
  .student-info .student-name { font-weight: 800; font-size: 1rem; }
  .student-info .student-detail { font-size: 0.8rem; color: var(--muted); margin-top: 3px; line-height: 1.4; }

  .modal-rewards {
    background: rgba(247,201,72,0.08); border: 1px solid rgba(247,201,72,0.2);
    border-radius: 12px; padding: 16px; margin-bottom: 24px;
  }
  .modal-rewards-title { font-size: 0.8rem; font-weight: 700; color: var(--accent); margin-bottom: 10px; }
  .reward-list { display: flex; gap: 8px; flex-wrap: wrap; }
  .reward-pill {
    background: rgba(247,201,72,0.15); border: 1px solid rgba(247,201,72,0.3);
    color: var(--accent); font-size: 0.75rem; font-weight: 700;
    padding: 4px 12px; border-radius: 20px;
  }

  .modal-actions { display: flex; gap: 12px; }
  .btn-primary {
    flex: 1; padding: 14px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000; font-family: 'Nunito', sans-serif;
    font-weight: 800; font-size: 1rem;
    border: none; border-radius: 14px; cursor: pointer;
    transition: all 0.3s;
  }
  .btn-primary:hover { transform: scale(1.03); box-shadow: 0 8px 30px rgba(247,201,72,0.3); }
  .btn-secondary {
    padding: 14px 24px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    color: var(--text); font-family: 'Nunito', sans-serif;
    font-weight: 700; border-radius: 14px; cursor: pointer;
    transition: all 0.2s;
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.12); }

  /* SUCCESS MODAL */
  .success-modal .modal-title { color: var(--accent3); }
  .confetti-line {
    font-size: 1.5rem; letter-spacing: 4px;
    text-align: center; margin-bottom: 20px;
    animation: bounce-in 0.6s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes bounce-in { from { transform: scale(0); } to { transform: scale(1); } }

  .xp-gained {
    text-align: center; font-size: 2rem; font-family: 'Fredoka One', cursive;
    color: var(--accent); margin: 16px 0;
    animation: pop-in 0.8s 0.3s both;
  }
  @keyframes pop-in { from { transform: scale(0) rotate(-10deg); opacity:0; } to { transform: scale(1) rotate(0deg); opacity:1; } }

  .unlocked-stuff {
    background: rgba(78,205,196,0.1); border: 1px solid rgba(78,205,196,0.3);
    border-radius: 12px; padding: 16px; margin: 16px 0;
  }
  .unlocked-title { font-size: 0.8rem; color: var(--accent3); font-weight: 700; margin-bottom: 8px; }
  .unlocked-item { font-size: 0.85rem; margin-bottom: 4px; }

  /* FLOATING PARTICLES */
  .particle {
    position: fixed; pointer-events: none; z-index: 9999;
    font-size: 1.5rem;
    animation: float-up 2s ease-out forwards;
  }
  @keyframes float-up {
    0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
    20% { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
    100% { transform: translate(-50%, -120px) scale(0.8); opacity: 0; }
  }

  /* TOOLTIP */
  .tooltip {
    position: fixed; background: rgba(22,22,42,0.95);
    border: 1px solid rgba(247,201,72,0.3);
    color: var(--text); padding: 8px 14px;
    border-radius: 8px; font-size: 0.8rem;
    pointer-events: none; z-index: 9998;
    opacity: 0; transition: opacity 0.2s;
    max-width: 200px;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .char-layout { grid-template-columns: 1fr; }
    main { padding: 16px; }
    header { padding: 12px 16px; }
    .logo { font-size: 1.3rem; }
    .worlds-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .worlds-grid { grid-template-columns: 1fr; }
    .nav-tabs .tab-btn span { display: none; }
  }

  /* LEVEL UP ANIMATION */
  .levelup-toast {
    position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000; padding: 14px 28px;
    border-radius: 50px; font-family: 'Fredoka One', cursive;
    font-size: 1.1rem; z-index: 9999;
    animation: toast-in-out 3s ease forwards;
    pointer-events: none;
  }
  @keyframes toast-in-out {
    0% { opacity: 0; transform: translateX(-50%) translateY(-20px); }
    15% { opacity: 1; transform: translateX(-50%) translateY(0); }
    75% { opacity: 1; transform: translateX(-50%) translateY(0); }
    100% { opacity: 0; transform: translateX(-50%) translateY(-20px); }
  }
</style>
</head>
<body>

<div class="stars"></div>

<div class="app">
  <!-- HEADER -->
  <header>
    <div class="logo">Orient<span>Quest</span> 🗺️</div>
    <div class="nav-tabs">
      <button class="tab-btn active" onclick="showView('map')">🌍 <span>Univers</span></button>
      <button class="tab-btn" onclick="showView('character')">🎒 <span>Mon Profil</span></button>
    </div>
    <div class="header-right">
      <div class="player-mini" onclick="showView('character')">
        <div class="avatar-mini" id="headerAvatar">
